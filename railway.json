{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "mvn -pl gift-quiz-server -am package -DskipTests"
  },
  "deploy": {
    "startCommand": "java -jar gift-quiz-server/target/gift-quiz-server-1.0.0-SNAPSHOT.jar",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
